{
    "optim": {
        "precision": "bf16-mixed",
        "num_devices": 1,
        "num_nodes": 1,
        "accumulate_grad_batches": 1,
        "strategy": "auto",
        "gradient_clip_val": 0,
        "num_workers": 4,
        "persistent_workers": false,
        "pin_memory": true,
        "train_batch_size": 128
    },
    "dataset": {
        "allowed_ring_size": [3, 4, 5, 6, 7],
        "allowed_charges": null,
        "allowed_spins": null,
        "self_loop": true,
        "target_list": ["success"],
        "element_set": [
            "Ac", "Am", "As", "B", "Bk", "Br", "C", "Cf", "Cl", "Cm",
            "Es", "F", "Fm", "Ge", "H", "I", "Lr", "Md", "N", "No",
            "Np", "O", "P", "Pa", "Pu", "S", "Sb", "Se", "Si", "Te",
            "Th", "U"
        ],
        "bond_key": "bonds",
        "map_key": null,
        "val_prop": 0.15,
        "test_prop": 0.1,
        "train_batch_size": 128,
        "seed": 42,
        "debug": false,
        "num_workers": 4,
        "extra_dataset_info": {},
        "log_scale_features": false,
        "log_scale_targets": false,
        "standard_scale_features": true,
        "standard_scale_targets": false,
        "extra_keys": {
            "atom": [],
            "bond": [],
            "global": ["success"]
        },
        "rbf_cutoff": 5.0,
        "impute": false,
        "verbose": true,
        "train_lmdb": "data/oact_classifier/actinides_lmdb/train/",
        "val_lmdb": "data/oact_classifier/actinides_lmdb/val/",
        "test_lmdb": "data/oact_classifier/actinides_lmdb/test/"
    },
    "model": {
        "classifier": true,
        "conv_fn": "ResidualBlock",
        "target_dict": {
            "global": ["success"]
        },
        "dropout": 0.2,
        "batch_norm": true,
        "batch_norm_tf": true,
        "activation": "ReLU",
        "bias": true,
        "norm": "both",
        "aggregate": "sum",
        "n_conv_layers": 6,
        "resid_n_graph_convs": 2,
        "lr": 0.001,
        "weight_decay": 1e-4,
        "lr_plateau_patience": 25,
        "lr_scale_factor": 0.5,
        "scheduler_name": "reduce_on_plateau",
        "loss_fn": "cross_entropy",
        "embedding_size": 64,
        "shape_fc": "cone",
        "fc_hidden_size_1": 256,
        "fc_num_layers": 3,
        "fc_dropout": 0.2,
        "fc_batch_norm": true,
        "output_dims": 2,
        "global_pooling_fn": "SumPoolingThenCat",
        "pooling_ntypes": ["atom", "bond", "global"],
        "pooling_ntypes_direct": ["global"],
        "lstm_iters": 3,
        "lstm_layers": 2,
        "num_heads_gat": 2,
        "dropout_feat_gat": 0.2,
        "dropout_attn_gat": 0.2,
        "hidden_size": 64,
        "hidden_size_gat": 64,
        "residual_gat": true,
        "restore": false,
        "max_epochs": 500,
        "compiled": false,
        "extra_stop_patience": 5,
        "ntasks": 1,
        "initializer": "kaiming",
        "class_weights": [10.9, 1.0]
    }
}
